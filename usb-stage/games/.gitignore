# Game payloads are large and third-party -- NEVER committed.
# Only scaffolding is tracked: this file, README.md, fetch-games.sh, and each
# game directory's .gitkeep placeholder. Populate with fetch-games.sh, then copy
# the whole games/ tree to the USB stick root (/data/UsbDisk1/Volume1/games/).
/*/*
!/*/.gitkeep
# our own small self-contained games (not third-party payloads) -> tracked
!/freecell/index.html
!/sudoku/index.html
!/wordle/index.html
!/minesweeper/index.html
!/tetris/index.html
!/solitaire/index.html
!/mahjong/index.html
